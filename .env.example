# ==============================================================================
# .env.example  —  Copy to .env and fill in ALL values before running
# NEVER commit .env to version control
# ==============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=hub
POSTGRES_USER=hubuser
POSTGRES_PASSWORD=changeme_strong_password

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_strong_password

# ── JWT Secrets (generate with: openssl rand -hex 64) ─────────────────────────
JWT_ACCESS_SECRET=replace_with_64_byte_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_byte_random_hex_string

# ── Worker ↔ API Shared Secret (generate with: openssl rand -hex 32) ──────────
WORKER_SECRET=replace_with_32_byte_random_hex_string

# ── Redis (optional password for production) ──────────────────────────────────
# REDIS_PASSWORD=your_redis_password
